library(DAAG)
dat <- DAAG::leafshape17
set.seed(1234)
n = nrow(dat)
train_ind <- sample(1:n, size = round(0.8 * n))
train = dat[train_ind,]
valid = dat[-train_ind,]
# xtrain <- train[, vars]
# ytrain <- train$site
# LDA
m1 = lda(arch~logwid+loglen, data = train)
m1
#
# mean(valid$y!=pre1$class)
# QDA
m2 = qda(arch~logwid+loglen, data = train)
m2
#
pre1 = predict(m1, newdata = valid)
pre2 = predict(m2, newdata = valid)
library(ROCR)
lda_pre = pre1$posterior[,2]
# head(lda_pre)
qda_pre = pre2$posterior[,2]
# head(qda_pre)
#Use prediction() and performance() to get TPR and FPR
pred_lda = prediction(lda_pre,valid$arch)
perf_lda = performance(pred_lda, "tpr", "fpr")
pred_qda = prediction(qda_pre,valid$arch)
perf_qda = performance(pred_qda, "tpr", "fpr")
AUC_lda = performance(pred_lda,"auc")@y.values[[1]]
AUC_qda = performance(pred_qda,"auc")@y.values[[1]]
data.frame(model=c("LDA","QDA"),AUC=c(AUC_lda,AUC_qda))
#Plot ROC Curves
par(mfrow=c(1,2))
plot(perf_lda, colorize=TRUE, main="LDA Test")
plot(perf_qda, colorize=TRUE, main="QDA Test")
